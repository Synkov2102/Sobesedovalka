# Copy to .env and adjust. Do not commit .env.
PORT=3000

# Required for JWT (register / login). Use a long random string in production.
JWT_SECRET=change-me-to-a-long-random-secret

# Required. Collab uses collections collab_rooms, collab_files, collab_folders, collab_peers (native driver, no Mongoose).
MONGODB_URI=mongodb://USER:PASSWORD@HOST:27017/sobesedovalka?authSource=sobesedovalka

# Optional: override database name instead of the one in the URI path
# MONGODB_DB=sobesedovalka
